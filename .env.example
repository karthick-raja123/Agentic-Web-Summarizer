# ============================================================================
# ENVIRONMENT VARIABLES - QuickGlance Multi-Agent Pipeline
# ============================================================================
# Copy this file to .env and fill in your actual values
# Production: Store secrets in your hosting platform's secret manager
#
# Locations:
# - Render: Environment Variables > Secrets
# - Railway: Variables > Secrets
# - HuggingFace Spaces: Settings > Repository secrets
# ============================================================================

# ============================================================================
# API KEYS (REQUIRED)
# ============================================================================

# Google Generative AI (Gemini)
# Get from: https://makersuite.google.com/app/apikey
GOOGLE_API_KEY=your_google_api_key_here

# Serper Search API
# Get from: https://serper.dev/api
SERPER_API_KEY=your_serper_api_key_here

# ============================================================================
# FASTAPI CONFIGURATION
# ============================================================================

# API Server
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=false  # Set to true only in development

# CORS Configuration
ALLOWED_ORIGINS=*  # Restrict in production: ["https://yourdomain.com"]
ALLOW_CREDENTIALS=true
ALLOW_METHODS=["GET", "POST", "PUT", "DELETE"]
ALLOW_HEADERS=["*"]

# ============================================================================
# STREAMLIT CONFIGURATION
# ============================================================================

# Streamlit Server
STREAMLIT_SERVER_PORT=8501
STREAMLIT_SERVER_ADDRESS=0.0.0.0
STREAMLIT_SERVER_HEADLESS=true
STREAMLIT_CLIENT_TOOLBAR_MODE=viewer  # or developer
STREAMLIT_THEME_BASE=dark
STREAMLIT_THEME_PRIMARY_COLOR=#00D9FF

# ============================================================================
# APPLICATION SETTINGS
# ============================================================================

# Logging
LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR, CRITICAL
DEBUG_MODE=false

# Timeouts (seconds)
REQUEST_TIMEOUT=60
SEARCH_TIMEOUT=30
SCRAPE_TIMEOUT=20

# Pipeline Configuration
ENABLE_EVALUATION=true
ENABLE_FORMATTING=true
ENABLE_AUDIO=true

# ============================================================================
# DEPLOYMENT SETTINGS
# ============================================================================

# Environment Type
ENVIRONMENT=production  # development, staging, production

# Database (if using)
# DATABASE_URL=postgresql://user:password@localhost/dbname

# Redis Cache (optional)
# REDIS_URL=redis://localhost:6379/0

# ============================================================================
# MONITORING & ANALYTICS (OPTIONAL)
# ============================================================================

# Error Tracking (Sentry)
# SENTRY_DSN=https://key@sentry.io/project

# Analytics (PostHog)
# POSTHOG_API_KEY=your_posthog_key

# ============================================================================
# NOTES FOR DEPLOYMENT PLATFORMS
# ============================================================================
#
# RENDER.COM:
# - Set secrets in Environment Variables > Secrets
# - Example: GOOGLE_API_KEY, SERPER_API_KEY
#
# RAILWAY.APP:
# - Set variables in Variables > Secrets
# - Automatically loaded into environment
#
# HUGGINGFACE SPACES:
# - Use Spaces > Settings > Repository secrets
# - Or set directly in Space Settings > Secrets
#
# AWS/HEROKU/OTHER:
# - Use their respective secret management systems
#
# ============================================================================
