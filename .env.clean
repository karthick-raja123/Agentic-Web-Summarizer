# ============================================================================
# QUICKGLANCE - ENVIRONMENT CONFIGURATION
# ============================================================================
# Copy this to .env and fill in your actual values
# Production: Store secrets in hosting platform secret managers
# ============================================================================

# ============================================================================
# REQUIRED API KEYS
# ============================================================================

# Google Generative AI (Gemini)
# Get from: https://makersuite.google.com/app/apikey
GOOGLE_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Serper Search API
# Get from: https://serper.dev/api
SERPER_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ============================================================================
# FASTAPI CONFIGURATION
# ============================================================================
API_HOST=127.0.0.1
API_PORT=8000
API_ENVIRONMENT=development  # development or production
API_RELOAD=false

# ============================================================================
# REQUEST CONFIGURATION
# ============================================================================
REQUEST_TIMEOUT=30           # Timeout for external API calls (seconds)
SERPER_TIMEOUT=15            # Serper API timeout
SCRAPE_TIMEOUT=10            # Web scraping timeout
RETRIES_MAX=3                # Max retry attempts
RETRY_DELAY=2.0              # Delay between retries (seconds)

# ============================================================================
# CONTENT LIMITS
# ============================================================================
MAX_CONTENT_PER_URL=10000     # Max chars from each URL
MAX_TOTAL_CONTENT=50000       # Max combined content size
MAX_SEARCH_RESULTS=10         # Max search results
MAX_URLS_TO_SCRAPE=5          # Max URLs to scrape

# ============================================================================
# DEBUG & LOGGING
# ============================================================================
DEBUG=false                   # Enable debug mode (verbose logging)
LOG_LEVEL=INFO                # DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_FILE=logs/quickglance.log

# ============================================================================
# STREAMLIT CONFIGURATION
# ============================================================================
STREAMLIT_SERVER_PORT=8501
STREAMLIT_SERVER_ADDRESS=127.0.0.1
STREAMLIT_SERVER_HEADLESS=false
STREAMLIT_THEME_BASE=dark

# ============================================================================
# FEATURE FLAGS
# ============================================================================
ENABLE_EVALUATION=true        # Enable content evaluation agent
ENABLE_FORMATTING=true        # Enable output formatting agent
ENABLE_CACHING=false          # Cache search results
ENABLE_AUDIO_OUTPUT=false     # Text-to-speech output

# ============================================================================
# CORS CONFIGURATION
# ============================================================================
ALLOWED_ORIGINS=http://localhost:8501,http://localhost:3000,http://127.0.0.1:8501
